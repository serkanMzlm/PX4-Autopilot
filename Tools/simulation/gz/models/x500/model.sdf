<?xml version="1.0" encoding="UTF-8"?>
<sdf version='1.9'>
<model name='x500'>
	<pose>-4 2 0.2 0 0 0</pose>
	<self_collide>false</self_collide>
	<static>false</static>
	<link name="base_link">
		<inertial>
			<mass> 1.9 </mass>
			<inertia>
				<ixx>0.027608</ixx>
				<ixy>-0.000018</ixy>
				<ixz>-0.00001</ixz>
				<iyy>0.035319</iyy>
				<iyz>-0.000415</iyz>
				<izz>0.055487</izz>
			</inertia>
		</inertial>
		<gravity>true</gravity>
		<velocity_decay/>
		<visual name="base_link_visual">
			<pose>0 0 0 0 0 -1.57</pose>
			<geometry>
				<mesh>
					<uri>model://x500/meshes/DRONE_MONTAJ.STL</uri>
				</mesh>
			</geometry>
			<material>
				<ambient>0.5 0.75 0 1</ambient>
				<diffuse>0.7 0.9 0 1</diffuse>
				<emissive>0.1 0 0.1 1</emissive>
			</material>
		</visual>
		<collision name="base_link_collision_0">
			<pose>0.02 0 -0.025 0 0 0</pose>
			<geometry>
				<box>
					<size>0.42 0.337 0.2</size>
				</box>
			</geometry>
			<surface>
				<contact>
					<ode>
					<min_depth>0.001</min_depth>
					<max_vel>0</max_vel>
					</ode>
				</contact>
				<friction>
					<ode/>
				</friction>
			</surface>
		</collision>

		<light name="left_light_source" type="spot">
			<visualize>false</visualize>
			<pose>0.14 0 -0.003 0 -1.57 0</pose>
			<attenuation>
				<range>10</range>
				<linear>0</linear>
				<constant>0.1</constant>
				<quadratic>0.0025</quadratic>
			</attenuation>
			<diffuse>0.8 0.8 0.5 1</diffuse>
			<specular>0.8 0.8 0.5 1</specular>
			<spot>
				<inner_angle>1</inner_angle>
				<outer_angle>1.1</outer_angle>
				<falloff>1</falloff>
			</spot>
			<direction>0 0 -1</direction>
			<cast_shadows>1</cast_shadows>
		</light>

		<sensor name="air_pressure_sensor" type="air_pressure">
			<always_on>1</always_on>
			<update_rate>50</update_rate>
			<air_pressure>
				<pressure>
					<noise type="gaussian">
					<mean>0</mean>
					<stddev>0.01</stddev>
					</noise>
				</pressure>
			</air_pressure>
		</sensor>

		<sensor name="imu_sensor" type="imu">
			<always_on>1</always_on>
			<update_rate>250</update_rate>
		</sensor>

		<sensor name="Vision_camera" type="camera">
			<pose>0.1235 0 -0.003 0 0 0</pose>
			<topic>camera_vision</topic>
			<camera>
				<horizontal_fov>1.3</horizontal_fov>
				<image>
					<width>480</width>
					<height>480</height>
				</image>
			</camera>
			<always_on>1</always_on>
			<update_rate>35</update_rate>
			<visualize>true</visualize>
		</sensor>

