  <link name="KAMERA">
      <pose> 0.1235 0 -0.003 0 0 -1.57 </pose>
      <inertial>
    <pose> 0 0 0 0 0 0 </pose>
    <mass> 0.022401</mass>
    <inertia>
      <ixx>4.252E-06</ixx>
      <ixy>-1.544E-10</ixy>
      <ixz>-2.1481E-07</ixz>
      <iyy>5.7219E-06</iyy>
      <iyz>-1.0484E-09</iyz>
      <izz>6.2901E-06</izz>
    </inertia>
      </inertial>
      <visual name= "kamera_visual">
        <pose> 0 0 0 0 0 0 </pose>
        <geometry>
          <mesh>
            <uri>model://x500/meshes/KAMERA_MONTAJ.STL</uri>
          </mesh>
