		<sensor name="depth_camera_on" type="depth_camera">
			<pose>0.14 0.0 -0.045 0 0 0</pose>
			<update_rate>4</update_rate>
			<topic>depth_camera_on</topic>
			<visualize>true</visualize>
			<camera>
				<horizontal_fov>0.785</horizontal_fov>
				<image>
					<width>8</width>
					<height>8</height>
					<format>R_FLOAT32</format>
				</image>
				<clip>
					<near>0.05</near>
					<far>2.0</far>
				</clip>
				<noise>
					<type>gaussian</type>
					<mean>0</mean>
					<stddev>0.005</stddev>
				</noise>
			</camera>
		</sensor>

